# API Gateway Environment Configuration
# Copy this file to .env and fill in the values.

# Server
PORT=8000
NODE_ENV=development
COOKIE_DOMAIN=.dailyexpress.app

# Auth
JWT_SECRET=replace-with-a-long-jwt-secret
JWT_REFRESH_SECRET=replace-with-a-long-refresh-secret
INTERNAL_SERVICE_TOKEN=replace-with-a-long-random-internal-token

# CORS
CORS_ORIGINS=http://localhost:3000,http://localhost:3001,https://dailyexpress.app,https://driver.dailyexpress.app
TRUST_PROXY_HOPS=0
ENABLE_PROXY_IP_DEBUG=false
PROXY_IP_DEBUG_TOKEN=

# Rate limiting
RATE_LIMIT_PUBLIC_AUTH=20
RATE_LIMIT_PUBLIC_ROUTES=60
RATE_LIMIT_PROTECTED=100
RATE_LIMIT_UPSTASH_REDIS_REST_URL=
RATE_LIMIT_UPSTASH_REDIS_REST_TOKEN=

# Upstream services
AUTH_SERVICE_URL=http://localhost:5001
DRIVER_SERVICE_URL=http://localhost:5002
ROUTE_SERVICE_URL=http://localhost:5004
PAYMENT_SERVICE_URL=http://localhost:5005
PAYOUT_SERVICE_URL=http://localhost:5006
NOTIFICATION_SERVICE_URL=http://localhost:5007

# Observability
SENTRY_DSN=
SENTRY_ENVIRONMENT=development
SENTRY_RELEASE=
SENTRY_ERROR_SAMPLE_RATE=1
SENTRY_TRACES_SAMPLE_RATE=0
