{
  "extends": "@repo/typescript-config/nextjs.json",
  "compilerOptions": {
    "plugins": [
      {
        "name": "next"
      }
    ],
    "paths": {
      "@/*": ["./src/*"],
      "~/*": ["./app/*"],
      "@repo/ui/*": ["../../packages/ui/src/*"],
      "@repo/types/*": ["../../packages/types/*"],
      "@repo/api": ["../../packages/api/index.ts"],
      "@shared/*": ["../../shared/*"],
      "@shared/types": ["../../shared/types/index.ts"],
      "@shared/types/*": ["../../shared/types/*"]
    }
  },
  "include": [
    "**/*.ts",
    "**/*.tsx",
    "next-env.d.ts",
    "next.config.js",
    ".next/types/**/*.ts"
  ],
  "exclude": ["node_modules"]
}
