{
  "compilerOptions": {
    "module": "ESNext",
    "moduleResolution": "bundler",
    "target": "ESNext",
    "lib": [
      "ESNext"
    ],
    "strict": true,
    "skipLibCheck": true,
    "types": [
      "bun-types"
    ]
  },
  "include": [
    "scripts/*.ts"
  ],
  "exclude": [
    "opensrc"
  ]
}
