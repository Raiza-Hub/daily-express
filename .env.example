# Shared workspace environment
# Copy this file to /Users/raiza/Desktop/daily-express/.env and fill in the values.
# Backend services and the API gateway load this file first, then their local .env files override service-specific keys.

# Frontend/runtime URLs
NEXT_PUBLIC_API_GATEWAY_URL=http://localhost:8000
NEXT_PUBLIC_WEB_APP_URL=http://localhost:3000
NEXT_PUBLIC_DRIVER_APP_URL=http://localhost:3001
WEB_APP_URL=http://localhost:3000
FRONTEND_URL=http://localhost:3000
DRIVER_APP_URL=http://localhost:3001

# Shared backend service config
AUTH_SERVICE_URL=http://localhost:5001
DRIVER_SERVICE_URL=http://localhost:5002
ROUTE_SERVICE_URL=http://localhost:5004
PAYMENT_SERVICE_URL=http://localhost:5005
PAYOUT_SERVICE_URL=http://localhost:5006
NOTIFICATION_SERVICE_URL=http://localhost:5007
INTERNAL_SERVICE_TOKEN=replace-with-a-long-random-internal-token
JWT_SECRET=replace-with-a-long-jwt-secret
JWT_REFRESH_SECRET=replace-with-a-long-refresh-secret
SESSION_SECRET=replace-with-a-long-session-secret
SESSION_UPSTASH_REDIS_REST_URL=
SESSION_UPSTASH_REDIS_REST_TOKEN=
KAFKA_IDEMPOTENCY_UPSTASH_REDIS_REST_URL=
KAFKA_IDEMPOTENCY_UPSTASH_REDIS_REST_TOKEN=
KAFKA_BROKERS=localhost:9092
SCHEMA_REGISTRY_URL=http://localhost:8081
CORS_ORIGINS=http://localhost:3000,http://localhost:3001
ROUTE_SERVICE_TIMEZONE=Africa/Lagos

# Auth/identity integrations
COOKIE_DOMAIN=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:8000/api/auth/v1/auth/google/callback
EMAIL_BRAND_NAME=Daily Express
SUPPORT_EMAIL=support@dailyexpress.app

# Driver/media integrations
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_SECRET_KEY=

# Shared payments config
KORA_SECRET_KEY=
KORA_WEBHOOK_SECRET=
KORA_WEBHOOK_URL=http://localhost:8000/api/payments/v1/payments/webhooks/kora
PAYMENT_PUBLIC_BASE_URL=http://localhost:8000/api/payments

# Shared platform integrations
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=
LOCATION_UPSTASH_REDIS_REST_URL=
LOCATION_UPSTASH_REDIS_REST_TOKEN=
NOTIFICATION_UPSTASH_REDIS_REST_URL=
NOTIFICATION_UPSTASH_REDIS_REST_TOKEN=
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
DISABLE_LOCATION_SUGGESTIONS_CACHE=false
UPSTASH_LOCATION_SUGGEST_LIMIT=500
UPSTASH_LOCATION_PLACE_LIMIT=500

# Mail delivery
EMAIL_FROM=noreply@dailyexpress.local
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=

# Backend observability
SENTRY_DSN=
SENTRY_ENVIRONMENT=development
SENTRY_RELEASE=
SENTRY_ENABLE_LOGS=true
SENTRY_TRACES_SAMPLE_RATE=1
SENTRY_SEND_DEFAULT_PII=true

# Product analytics
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=/daily-express-flow
NEXT_PUBLIC_POSTHOG_UI_HOST=https://us.posthog.com

# Note:
# Keep service-local keys such as PORT, DATABASE_URL, KAFKA_CLIENT_ID, and
# KORA_TIMEOUT_MS inside each package/service .env file when you want an override.
