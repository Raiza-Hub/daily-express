{
  "name": "@dailyexpress-api",
  "version": "1.0.0",
  "description": "Daily Express API - consolidated API with shared database access",
  "type": "module",
  "main": "index.ts",
  "private": true,
  "scripts": {
    "dev": "bun --watch index.ts",
    "start": "bun index.ts",
    "db:generate": "bun x drizzle-kit generate",
    "db:push": "bun x drizzle-kit push",
    "db:pull": "bun x drizzle-kit pull",
    "db:migrate": "bun x drizzle-kit migrate",
    "db:studio": "bun x drizzle-kit studio",
    "db:clear": "bun run scripts/clear-db.ts --yes",
    "db:seed:payment-payout": "bun run scripts/seed-payment-payout-flow.ts"
  },
  "dependencies": {
    "@aws-sdk/client-sesv2": "^3.1048.0",
    "@repo/email": "workspace:*",
    "@sentry/bun": "10.53.1",
    "@types/multer": "^2.1.0",
    "@upstash/realtime": "^1.0.3",
    "@upstash/redis": "^1.38.0",
    "axios": "^1.16.1",
    "bcryptjs": "^3.0.3",
    "cloudinary": "^2.10.0",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "drizzle-orm": "^0.45.2",
    "express": "^5.2.1",
    "express-rate-limit": "^8.5.1",
    "google-auth-library": "^10.6.2",
    "helmet": "^8.1.0",
    "joi": "^18.2.1",
    "jsonwebtoken": "^9.0.3",
    "multer": "^2.1.1",
    "pg-boss": "^12.18.2",
    "postgres": "^3.4.9",
    "rate-limit-redis": "^5.0.0",
    "shared": "workspace:*",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/bcryptjs": "^3.0.0",
    "@types/bun": "^1.3.14",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^25.7.0",
    "drizzle-kit": "^0.31.10",
    "typescript": "^6.0.3"
  }
}
