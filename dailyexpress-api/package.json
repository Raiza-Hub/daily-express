{
  "name": "@dailyexpress-api",
  "version": "1.0.0",
  "description": "Daily Express API - consolidated API with shared database access",
  "type": "module",
  "main": "index.ts",
  "private": true,
  "scripts": {
    "dev": "bun --watch index.ts",
    "start": "bun index.ts",
    "db:generate": "bun x drizzle-kit generate",
    "db:push": "bun x drizzle-kit push",
    "db:pull": "bun x drizzle-kit pull",
    "db:migrate": "bun x drizzle-kit migrate",
    "db:studio": "bun x drizzle-kit studio",
    "db:clear": "bun run scripts/clear-db.ts --yes",
    "db:seed:payment-payout": "bun run scripts/seed-payment-payout-flow.ts"
  },
  "dependencies": {
    "@repo/email": "workspace:*",
    "@sentry/bun": "10.50.0",
    "@types/multer": "^2.1.0",
    "@upstash/realtime": "^1.0.3",
    "@upstash/redis": "^1.36.3",
    "axios": "^1.8.0",
    "bcryptjs": "^2.4.3",
    "cloudinary": "^2.10.0",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^17.3.1",
    "drizzle-orm": "^0.45.1",
    "express": "^5.2.1",
    "express-rate-limit": "^7.5.0",
    "google-auth-library": "^10.6.2",
    "helmet": "^8.0.0",
    "joi": "^17.13.3",
    "jsonwebtoken": "^9.0.2",
    "multer": "^2.1.1",
    "nodemailer": "^8.0.7",
    "pg-boss": "^12.18.2",
    "postgres": "^3.4.8",
    "rate-limit-redis": "^4.3.1",
    "shared": "workspace:*",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/bun": "latest",
    "@types/express": "^5.0.2",
    "@types/jsonwebtoken": "^9.0.9",
    "@types/node": "^25.5.0",
    "@types/nodemailer": "^8.0.0",
    "drizzle-kit": "^0.31.10",
    "typescript": "^6.0.3"
  }
}
