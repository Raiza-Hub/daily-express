# ========================================
# DailyExpress API — Environment Variables
# ========================================
# Copy this file to .env and fill in your values.
#   cp .env.example .env
# ========================================

# ── Server ──────────────────────────────
PORT=8000
NODE_ENV=development
TRUST_PROXY_HOPS=0

# ── JWT ─────────────────────────────────
JWT_SECRET=your-jwt-secret-at-least-32-chars
JWT_REFRESH_SECRET=your-jwt-refresh-secret-at-least-32-chars
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ── CORS ────────────────────────────────
CORS_ORIGINS=http://localhost:3000,http://localhost:3001,https://dailyexpress.app,https://driver.dailyexpress.app

# ── Database ────────────────────────────
DATABASE_URL=postgres://user:password@localhost:5432/dailyexpress_api

# ── OAuth (Google) ──────────────────────
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_CALLBACK_URL=http://localhost:8000/api/v1/auth/google/callback

# ── Email (Amazon SES API over HTTPS) ───
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your-aws-access-key-id
AWS_SECRET_ACCESS_KEY=your-aws-secret-access-key
EMAIL_FROM=noreply@yourdomain.com
EMAIL_BRAND_NAME=Daily Express
SUPPORT_EMAIL=support@yourdomain.com
SUPPORT_PHONE=+234 9063611541

# ── Frontend ────────────────────────────
FRONTEND_URL=http://localhost:3000
DRIVER_APP_URL=http://localhost:3001

# ── Rate Limiting ───────────────────────
# Layer 1: Cloudflare (edge) — configure 1 IP rule (300 req/min) in Cloudflare dashboard
# Layer 2: IP-based auth rate limit (express-rate-limit)
#   Protects unauthenticated auth endpoints (login, register, forgot-password)
RATE_LIMIT_PUBLIC_AUTH=20
RATE_LIMIT_UPSTASH_REDIS_REST_URL=https://your-upstash-redis-url.upstash.io
RATE_LIMIT_UPSTASH_REDIS_REST_TOKEN=your-upstash-redis-token

# ── Location Cache (Upstash) ─────────────
# Dedicated Upstash Redis for booking idempotency cache
LOCATION_UPSTASH_REDIS_REST_URL=https://your-location-upstash-url.upstash.io
LOCATION_UPSTASH_REDIS_REST_TOKEN=your-location-upstash-token

# Layer 3: Token bucket (per-user, per-action)
# Bookings: burst of 3, refill 1 every 60 seconds
TOKEN_BUCKET_BOOKING_CAPACITY=3
TOKEN_BUCKET_BOOKING_REFILL_RATE=1
TOKEN_BUCKET_BOOKING_REFILL_INTERVAL_SEC=60
# Payments: burst of 3, refill 1 every 60 seconds
TOKEN_BUCKET_PAYMENT_CAPACITY=3
TOKEN_BUCKET_PAYMENT_REFILL_RATE=1
TOKEN_BUCKET_PAYMENT_REFILL_INTERVAL_SEC=60
# Driver actions: burst of 10, refill 1 every 30 seconds
TOKEN_BUCKET_DRIVER_CAPACITY=10
TOKEN_BUCKET_DRIVER_REFILL_RATE=1
TOKEN_BUCKET_DRIVER_REFILL_INTERVAL_SEC=30

# ── Cookie ──────────────────────────────
COOKIE_DOMAIN=.yourdomain.com

# ── Auth ────────────────────────────────
BCRYPT_ROUNDS=10

# ── Admin API (Appsmith) ─────────────────
ADMIN_API_KEY=your-admin-api-key
# APPSMITH_SIGNATURE_SECRET=your-appsmith-signature-secret

# ── Route Service ───────────────────────
ROUTE_SERVICE_TIMEZONE=Africa/Lagos

# ── Runtime Debug ───────────────────────
ENABLE_PROXY_IP_DEBUG=false
# PROXY_IP_DEBUG_TOKEN=your-debug-token

# ── Payment & Payouts (Kora) ────────────
KORA_BASE_URL=https://api.korapay.com
KORA_SECRET_KEY=sk_test_your-kora-secret-key
KORA_WEBHOOK_URL=http://localhost:8000/api/v1/payments/webhooks/kora
KORA_TIMEOUT_MS=15000
PAYMENT_PUBLIC_BASE_URL=http://localhost:8000

# ── Payout Worker ───────────────────────
PAYOUT_RETRY_DELAYS_MS=60000,300000,900000
INSUFFICIENT_BALANCE_RETRY_DELAY_MS=1800000
PAYOUT_JOB_EXPIRE_MINUTES=15
MINIMUM_PAYOUT_BUFFER_MINOR=50000

# ── Cloudinary (Driver Uploads) ─────────
CLOUDINARY_CLOUD_NAME=your-cloudinary-cloud-name
CLOUDINARY_API_KEY=your-cloudinary-api-key
CLOUDINARY_API_SECRET=your-cloudinary-api-secret
CLOUDINARY_TIMEOUT_MS=30000

# ── Sentry ──────────────────────────────
SENTRY_DSN=https://your-sentry-dsn.ingest.sentry.io
SENTRY_ENVIRONMENT=development
SENTRY_RELEASE=
SENTRY_ERROR_SAMPLE_RATE=1.0
SENTRY_TRACES_SAMPLE_RATE=1.0
SENTRY_ENABLE_LOGS=true
SENTRY_SEND_DEFAULT_PII=false

# ── Logging ─────────────────────────────
DAILYEXPRESS_API_LOG_CONSOLE=false
