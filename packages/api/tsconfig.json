{
  "extends": "@repo/typescript-config/react-library.json",
  "compilerOptions": {
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "declaration": false,
    "declarationMap": false,
    "noEmit": true,
    "outDir": "dist",
    "baseUrl": ".",
    "paths": {
      "@repo/ui/*": ["./src/*"],
      "@shared/*": ["../../shared/*"]
    }
  },
  "include": ["src", "index.ts"],
  "exclude": ["node_modules", "dist"]
}
